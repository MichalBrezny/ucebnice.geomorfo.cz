{
  "name": "Jekyll",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "mounts": [
    "source=${localWorkspaceFolder}/../ucebnice.geomorfo.cz-site,target=/workspaces/ucebnice.geomorfo.cz-site,type=bind"
  ],

  "features": {
    "ghcr.io/devcontainers-contrib/features/prettier:1": {}
  },

  "forwardPorts": [8080],

  "postAttachCommand": "./bin/entry_point.sh",

  "customizations": {
    "vscode": {
      "extensions": ["esbenp.prettier-vscode", "sissel.shopify-liquid", "yzhang.markdown-all-in-one"],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "prettier.configPath": ".prettierrc",
        "editor.formatOnSave": true
      }
    }
  },

  "remoteUser": "vscode"
}